<!DOCTYPE html>
<html>
<head>
  <title>{{title}}</title>

  <style>
    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
      font-family: "Segoe UI", Arial, sans-serif;
    }

    body{
      background: linear-gradient(135deg,#bd4d94,#db7dbc);
      min-height:100vh;
      color:#f1f5f9;
      display:flex;
      justify-content:center;
      align-items:center;
      padding:40px;
    }

    .container{
      width:100%;
      max-width:1000px;
      background:white;
      color:#1e293b;
      padding:40px;
      border-radius:16px;
      box-shadow:0 20px 40px rgba(0,0,0,0.35);
    }

    header{
      text-align:center;
      margin-bottom:30px;
    }

    header h1{
      font-size:38px;
      color:#0f172a;
      margin-bottom:10px;
    }

    header p{
      color:#475569;
      font-size:18px;
    }

    .camisa-grid{
      display:grid;
      grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
      gap:20px;
      margin-top:30px;
    }

    .camisa-card{
      background:#f8fafc;
      border-radius:12px;
      padding:20px;
      box-shadow:0 10px 25px rgba(0,0,0,0.15);
      transition:0.3s;
      text-align:center;
    }

    .camisa-card:hover{
      transform:translateY(-6px);
      box-shadow:0 15px 35px rgba(0,0,0,0.25);
    }

    .camisa-card h3{
      margin-bottom:10px;
      color:#0f172a;
    }

    .price{
      font-size:22px;
      font-weight:bold;
      color:#2563eb;
      margin:10px 0;
    }

    button{
      background:#2563eb;
      border:none;
      padding:10px 18px;
      border-radius:6px;
      color:white;
      font-weight:bold;
      cursor:pointer;
      transition:0.3s;
    }

    button:hover{
      background:#1d4ed8;
      transform:scale(1.05);
    }

    footer{
      margin-top:30px;
      text-align:center;
      font-size:14px;
      color:#64748b;
    }

  </style>

</head>

<body>

  <div class="container">

    <header>
      <h1>{{title}}</h1>
      <p>Camisas modernas, confortáveis e perfeitas para qualquer estilo 👕</p>
    </header>

    {{{body}}}

    <footer>
      Loja de Camisas • Qualidade e estilo para você
    </footer>

  </div>

</body>
</html>