doctype html
html(lang='pt-BR')
  head
    meta(charset='UTF-8')
    meta(name='viewport', content='width=device-width, initial-scale=1.0')
    title Brownie House

    style.
      *{
        margin:0;
        padding:0;
        box-sizing:border-box;
      }

      body{
        min-height:100vh;
        font-family:"Georgia","Times New Roman",serif;
        color:#fff7f0;
        background:
          radial-gradient(circle at top left, rgba(120,70,30,0.3), transparent 30%),
          radial-gradient(circle at bottom right, rgba(90,40,20,0.3), transparent 35%),
          linear-gradient(135deg,#2b140a 0%,#3b1d0f 35%,#4a2413 65%,#2b140a 100%);
        overflow-x:hidden;
      }

      .page-shell{
        min-height:100vh;
        display:flex;
        align-items:center;
        justify-content:center;
        padding:40px 20px;
      }

      .store-frame{
        width:100%;
        max-width:1100px;
        border-radius:28px;
        padding:28px;
        background:rgba(255,255,255,0.05);
        border:1px solid rgba(255,255,255,0.1);
        backdrop-filter:blur(10px);
        box-shadow:0 20px 60px rgba(0,0,0,0.5);
      }

      .store-inner{
        border-radius:20px;
        overflow:hidden;
        background:linear-gradient(135deg,#4a2413,#2b140a);
      }

      .hero{
        padding:70px 40px 50px;
        text-align:center;
      }

      .badge{
        display:inline-block;
        margin-bottom:20px;
        padding:8px 16px;
        border-radius:999px;
        font-size:.8rem;
        letter-spacing:2px;
        text-transform:uppercase;
        background:rgba(255,255,255,0.1);
      }

      .hero h1{
        font-size:clamp(2.5rem,5vw,4rem);
        margin-bottom:20px;
      }

      .hero span{
        color:#ffd4a3;
      }

      .hero p{
        max-width:700px;
        margin:auto;
        line-height:1.8;
        opacity:.9;
      }

      .product-row{
        display:grid;
        grid-template-columns:repeat(4,1fr);
        gap:18px;
        padding:0 32px 32px;
      }

      .product-card{
        padding:24px;
        border-radius:18px;
        background:rgba(255,255,255,0.07);
        border:1px solid rgba(255,255,255,0.1);
        transition:.3s;
      }

      .product-card:hover{
        transform:translateY(-6px);
        background:rgba(255,255,255,0.1);
      }

      .product-card h3{
        margin-bottom:10px;
        color:#ffd8a8;
      }

      .product-card p{
        font-size:.95rem;
        line-height:1.6;
      }

      .content-area{
        padding:40px;
      }

      .content-box{
        border-radius:20px;
        padding:30px;
        background:rgba(255,255,255,0.05);
      }

      button{
        margin-top:20px;
        padding:14px 28px;
        border-radius:12px;
        border:none;
        background:#8b4513;
        color:white;
        font-weight:bold;
        cursor:pointer;
        transition:.3s;
      }

      button:hover{
        background:#a0522d;
        transform:scale(1.05);
      }

      .footer-note{
        text-align:center;
        padding:20px;
        font-size:.9rem;
        opacity:.8;
      }

      @media(max-width:900px){
        .product-row{
          grid-template-columns:repeat(2,1fr);
        }
      }

      @media(max-width:600px){
        .product-row{
          grid-template-columns:1fr;
        }
      }

  body
    .page-shell
      .store-frame
        .store-inner

          section.hero
            .badge brownies artesanais
            h1
              | Bem-vindo à 
              span Brownie House
            p
              | Brownies artesanais feitos com muito chocolate,
              | macios por dentro e com casquinha crocante por fora.
              | Escolha seu sabor favorito e aproveite!

          section.product-row
            .product-card
              h3 Brownie Tradicional
              p Chocolate intenso com textura macia e casquinha crocante.

            .product-card
              h3 Brownie com Nutella
              p Recheado com Nutella cremosa e muito chocolate.

            .product-card
              h3 Brownie com Oreo
              p Brownie super chocolatudo com pedaços de Oreo.

            .product-card
              h3 Brownie com Doce de Leite
              p Brownie macio com recheio generoso de doce de leite.

          section.content-area
            .content-box
              h2 Faça seu pedido 🍫
              p Escolha seus brownies favoritos e peça agora.
              button Comprar Brownie

          .footer-note
            p Brownie House • Feito com muito chocolate e carinho